# ------------------------------------------------------------------
# NexDyne — environment variables (copy to .env locally; set in Railway
# dashboard for production). VITE_* vars are baked in at BUILD time.
# ------------------------------------------------------------------

# --- Core (marketing-site launch) ---
NODE_ENV=production
# PORT is provided automatically by Railway; locally the server falls back to 3000.
# PORT=3000

# --- Database (MySQL) — optional for the static marketing site; required
#     once you use dynamic features (contact form storage, leads dashboard). ---
# Provision a MySQL plugin in Railway; it injects DATABASE_URL automatically.
DATABASE_URL=

# --- Auth / sessions — only needed when auth is turned on (currently dormant) ---
JWT_SECRET=

# --- Email (Resend) — set after verifying the sending domain in Resend ---
RESEND_API_KEY=
# Address you send transactional email FROM (must be on your verified domain)
EMAIL_FROM=noreply@yourdomain.com

# --- App-builder OAuth + Forge backend — LEAVE BLANK for marketing-only launch.
#     Fill only if you want login/admin + Forge-powered features live. ---
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# --- Client / build-time (VITE_*) — safe to expose in the browser bundle ---
VITE_APP_ID=nexdyne
VITE_APP_TITLE=NexDyne Consulting Group
# Google Analytics 4 measurement id (optional; silences the build warning)
VITE_GA_MEASUREMENT_ID=
# Only needed if auth is enabled:
VITE_OAUTH_PORTAL_URL=
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=
